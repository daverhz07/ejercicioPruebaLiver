# Archivo de configuración para ejecutar tests localmente en modo CI
# Uso: HEADED='' npm test

# Variables que se pueden usar:
# HEADED=true  - Ejecutar con pantalla (descomenta la línea siguiente)
# HEADED=''    - Ejecutar en headless (modo por defecto)

# Para ejecutar en modo headed:
# HEADED=true npm test

# Para ejecutar en CI (headless):
# HEADED='' npm test
